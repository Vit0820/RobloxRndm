HuntingTab:CreateToggle({
    Name         = "🚶 Enable Auto-Search (Walk to encounter)",
    CurrentValue = false,
    Flag         = "AutoSearchToggle",
    Callback     = function(value)
        autoSearchEnabled = value
        if value then
            -- Check if we have a character
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("Humanoid") or not char:FindFirstChild("HumanoidRootPart") then
                Rayfield:Notify({
                    Title    = "Error",
                    Content  = "Character not found!",
                    Duration = 3,
                    Image    = "alert-circle"
                })
                autoSearchEnabled = false
                return
            end
            
            -- Start loop if not already running
            if not getgenv().autoSearchRunning then
                getgenv().autoSearchRunning = true
                task.spawn(function()
                    local originPos = nil
                    local moveTarget = 1 -- 1 or -1 for direction
                    while task.wait(0.5) do
                        if not autoSearchEnabled then
                            getgenv().autoSearchRunning = false
                            break
                        end
                        
                        -- Pause walking if in battle
                        if inBattle then
                            task.wait(1)
                            continue
                        end
                        
                        local char = LocalPlayer.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
                            local hrp = char.HumanoidRootPart
                            local hum = char.Humanoid
                            
                            if not originPos then
                                originPos = hrp.Position
                            end
                            
                            -- Check distance from origin to decide when to turn around
                            local dist = (hrp.Position - originPos).Magnitude
                            if dist >= searchDistance then
                                moveTarget = moveTarget * -1 -- Flip direction
                                originPos = hrp.Position -- Reset origin to current pos to walk back
                            end
                            
                            -- Move (walk along LookVector)
                            local moveDir = hrp.CFrame.LookVector * (moveTarget * searchDistance)
                            hum:MoveTo(hrp.Position + moveDir)
                        end
                    end
                end)
            end
        else
            -- Stop moving if we disable it
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid:MoveTo(char.HumanoidRootPart.Position)
            end
        end
    end
})

