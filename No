---------------------------------------------------------------------------
--             DEBUG HOOK (All Remotes) — also feeds encounters
---------------------------------------------------------------------------

function startDebugHook()
    -- Connect to ALL RemoteEvents in ReplicatedStorage
    for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
        if desc:IsA("RemoteEvent") then
            local conn = desc.OnClientEvent:Connect(function(...)
                if not debugEnabled then return end

                local args = {...}

                -- Build the log string
                local argStr = ""
                for i, arg in ipairs(args) do
                    local s = tostring(arg)
                    if type(arg) == "table" then
                        local ok, json = pcall(function()
                            return HttpService:JSONEncode(arg)
                        end)
                        if ok then
                            s = json
                        else
                            s = "{table}"
                        end
                    end
                    argStr = argStr .. "[" .. i .. "] " .. s
                    if i < #args then argStr = argStr .. " | " end
                end

                local timestamp = os.date("%H:%M:%S")
                local logEntry = string.format("[%s] %s → %s", timestamp, desc.Name, argStr)

                -- Store the log
                table.insert(debugLog, 1, logEntry)
                if #debugLog > MAX_LOG_ENTRIES then
                    table.remove(debugLog)
                end

                -- Store raw args for encounter parsing
                table.insert(debugLogRaw, 1, { remoteName = desc.Name, args = args, time = timestamp })
                if #debugLogRaw > MAX_LOG_ENTRIES then
                    table.remove(debugLogRaw)
                end

                -- Update debug UI (only if showing logs)
                if showDebugLogs then
                    DebugParagraph:Set({
                        Title   = "Remote Spy Log (" .. #debugLog .. " entries)",
                        Content = table.concat(debugLog, "\n")
                    })
                end

                print("[PBB Debug] " .. logEntry)

                -- >>> FEED TO ENCOUNTER TRACKER <<<
                -- This is the bridge: debug spy captures the remote, then
                -- passes it to the encounter system for parsing
                processEncounter(desc.Name, args)
            end)

            table.insert(debugConnections, conn)
        end
    end

    -- Also watch for new remotes added later
    local addedConn = ReplicatedStorage.DescendantAdded:Connect(function(desc)
        if desc:IsA("RemoteEvent") and debugEnabled then
            local conn = desc.OnClientEvent:Connect(function(...)
                if not debugEnabled then return end
                local args = {...}

                local timestamp = os.date("%H:%M:%S")

                -- Build arg string
                local argStr = ""
                for i, arg in ipairs(args) do
                    local s = tostring(arg)
                    if type(arg) == "table" then
                        local ok, json = pcall(function()
                            return HttpService:JSONEncode(arg)
                        end)
                        if ok then s = json else s = "{table}" end
                    end
                    argStr = argStr .. "[" .. i .. "] " .. s
                    if i < #args then argStr = argStr .. " | " end
                end

                local logEntry = string.format("[%s] [NEW] %s → %s", timestamp, desc.Name, argStr)
                table.insert(debugLog, 1, logEntry)
                if #debugLog > MAX_LOG_ENTRIES then
                    table.remove(debugLog)
                end

                table.insert(debugLogRaw, 1, { remoteName = desc.Name, args = args, time = timestamp })
                if #debugLogRaw > MAX_LOG_ENTRIES then
                    table.remove(debugLogRaw)
                end

                if showDebugLogs then
                    DebugParagraph:Set({
                        Title   = "Remote Spy Log (" .. #debugLog .. " entries)",
                        Content = table.concat(debugLog, "\n")
                    })
                end

                -- Feed to encounter tracker
                processEncounter(desc.Name, args)
            end)
            table.insert(debugConnections, conn)
        end
    end)
    table.insert(debugConnections, addedConn)

    -- Hook __namecall if available (catches outgoing FireServer calls too)
    if hookmetamethod then
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            if debugEnabled and method == "FireServer" and self:IsA("RemoteEvent") then
                local selfName = self.Name
                local args = {...}
                local timestamp = os.date("%H:%M:%S")

                local argStr = ""
                for i, arg in ipairs(args) do
                    local s = tostring(arg)
                    if type(arg) == "table" then
                        local ok, json = pcall(function()
                            return HttpService:JSONEncode(arg)
                        end)
                        if ok then s = json else s = "{table}" end
                    end
                    argStr = argStr .. "[" .. i .. "] " .. s
                    if i < #args then argStr = argStr .. " | " end
                end

                local logEntry = string.format("[%s] [OUT] %s → %s", timestamp, selfName, argStr)
                table.insert(debugLog, 1, logEntry)
                if #debugLog > MAX_LOG_ENTRIES then
                    table.remove(debugLog)
                end

                if showDebugLogs then
                    DebugParagraph:Set({
                        Title   = "Remote Spy Log (" .. #debugLog .. " entries)",
                        Content = table.concat(debugLog, "\n")
                    })
                end

                print("[PBB Debug][OUT] " .. logEntry)
            end
            return oldNamecall(self, ...)
        end)
        print("[PBB Hub] Hooked __namecall metamethod")
    end

    print("[PBB Hub] Debug remote spy started — watching " .. #debugConnections .. " remotes")
end

function stopDebugHook()
    for _, conn in ipairs(debugConnections) do
        if conn and conn.Disconnect then
            conn:Disconnect()
        end
    end
    debugConnections = {}
    print("[PBB Hub] Debug hooks disconnected")
end

