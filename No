---------------------------------------------------------------------------
-- ENCOUNTER: called from the debug spy when any remote fires
---------------------------------------------------------------------------
local function processEncounter(remoteName, rawArgs)
    if not encounterEnabled then return end

    local eventType = rawArgs[1]
    if type(eventType) ~= "string" then return end

    -- Capture reference to the hashed remote for auto-catch/flee
    if not gameRemote then
        for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
            if desc:IsA("RemoteEvent") and desc.Name == remoteName then
                gameRemote = desc
                break
            end
        end
    end

    -- Handle request events (capture rqid for auto-catch/flee)
    if eventType == "BattleEvent" and rawArgs[3] == "request" then
        currentPlayerSide = rawArgs[4]
        currentRqId = rawArgs[5]
        -- Auto-catch/flee triggers on request (game is waiting for player input)
        if inBattle and (autoFleeEnabled or autoCatchShiny or autoCatchByName or autoCatchByLevel) then
            task.delay(0.3, function()
                local catch = shouldCatch({
                    Name = currentOpponentName or "",
                    Level = tostring(currentOpponentMaxHP or "?"),
                    IsShiny = false -- we stored this at encounter start
                })
                doAutoAction(catch)
            end)
        end
        return
    end

    if eventType ~= "BattleEvent" or rawArgs[3] ~= "update" then return end

    local battleId = rawArgs[2]
    local updateData = rawArgs[4]

    -- SAME battle: just update HP
    if battleId == lastBattleSessionId and inBattle then
        local newHP, ended = parseHPUpdate(updateData)
        if newHP then
            PokemonHP:Set({ Title = "Health", Content = newHP })
        end
        if ended then
            onBattleEnd()
        end
        return
    end

    -- NEW battle: parse opponent
    local data = parseUpdateForOpponent(updateData)
    if not data then
        EncounterStatus:Set({
            Title   = "Encounter Status",
            Content = "🟡 BattleEvent update received but couldn't find opponent (p2) data.\nCheck Debug tab for raw args."
        })
        return
    end

    lastBattleSessionId = battleId
    currentBattleId = battleId
    inBattle = true
    currentOpponentName = data.Name
    currentOpponentMaxHP = data.Level

    totalEncounters += 1
    if data.IsShiny then totalShinies += 1 end

    -- Update live UI
    EncounterStatus:Set({ Title = "Encounter Status", Content = "🟢 BATTLE DETECTED!" })
    PokemonName:Set({ Title = "Pokemon Name", Content = data.Name })
    PokemonLevel:Set({ Title = "Level", Content = "Lv. " .. data.Level })
    PokemonHP:Set({ Title = "Health", Content = data.HP })
    PokemonShiny:Set({ Title = "✨ Shiny?", Content = data.Shiny })

    TotalEncounters:Set("Total Encounters: " .. totalEncounters, "hash", Color3.fromRGB(255, 255, 255), false)
    ShinyCount:Set("Shinies Found: " .. totalShinies, "sparkles", Color3.fromRGB(255, 215, 0), false)

    -- History
    local timestamp = os.date("%H:%M:%S")
    local entry = string.format("[%s] %s | Lv.%s | HP: %s | Shiny: %s",
        timestamp, data.Name, data.Level, data.HP, data.Shiny)
    table.insert(encounterLog, 1, entry)
    if #encounterLog > MAX_LOG_ENTRIES then table.remove(encounterLog) end
    HistoryParagraph:Set({
        Title   = "Encounter History (" .. #encounterLog .. ")",
        Content = table.concat(encounterLog, "\n")
    })

    -- Notification
    if data.IsShiny then
        Rayfield:Notify({ Title = "✨ SHINY FOUND! ✨", Content = data.Name .. " (Lv." .. data.Level .. ") is SHINY!", Duration = 10, Image = "sparkles" })
    else
        Rayfield:Notify({ Title = "Wild Pokemon!", Content = data.Name .. " (Lv." .. data.Level .. ")", Duration = 4, Image = "swords" })
    end

    -- Webhook
    if (webhookOnAll) or (webhookOnShiny and data.IsShiny) then
        sendWebhook(data)
    end

    -- Console
    print(string.format("[PBB Hub] Encounter #%d: %s | Lv.%s | HP: %s | Shiny: %s",
        totalEncounters, data.Name, data.Level, data.HP, data.Shiny))

    -- Store shiny status for auto-catch decision
    -- We need this stored because the request event comes after the update
    getgenv().__pbb_lastShiny = data.IsShiny
    getgenv().__pbb_lastLevel = data.Level
    getgenv().__pbb_lastName = data.Name
end

