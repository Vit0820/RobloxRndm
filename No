---------------------------------------------------------------------------
--[[
    ACTUAL GAME PROTOCOL (from debug logs):
    
    The game uses ONE hashed RemoteEvent (e.g. "7d2686b7dee4...").
    The event TYPE is in arg[1] as a string: "BattleEvent", "HidePlayers", etc.
    
    BattleEvent structure:
      arg[1] = "BattleEvent"
      arg[2] = battle session ID (e.g. "YM;o3#G\"<6MC*tGBlV+d")
      arg[3] = sub-command: "update", "request", "inactiveside"
      arg[4+] = data
    
    The "update" sub-command (arg[3] == "update") sends a TABLE of
    pipe-delimited Showdown-like protocol strings in arg[4].
    
    Opponent Pokemon are p2 entries:
      |cache|1p2: Woobat|Woobat, L24, M|71/71|[icon]605|[ball]1|[owned]
      |switch|1p2a: Woobat|Woobat, L24, M|71/71
    
    Format of the details segment: "Name, LLevel, Gender" or "Name, LLevel, Gender, shiny"
    Shiny is indicated by ", shiny" at the end of the details string.
--]]

local lastBattleSessionId = nil  -- Track to avoid duplicate encounters per battle

-- Parse a single pipe-segment for p2 (opponent) Pokemon data
-- Returns { Name, Level, Gender, HP, MaxHP, IsShiny } or nil
local function parseP2Entry(segment)
    -- Match cache or switch entries for p2
    -- Examples:
    --   |cache|1p2: Woobat|Woobat, L24, M|71/71|[icon]605|[ball]1|[owned]
    --   |switch|1p2a: Woobat|Woobat, L24, M|71/71
    
    -- Split the segment by "|"
    local parts = {}
    for part in segment:gmatch("[^|]+") do
        table.insert(parts, part)
    end
    
    -- Look for a part that indicates p2 (opponent side)
    local isP2 = false
    local detailsPart = nil
    local hpPart = nil
    
    for i, part in ipairs(parts) do
        -- Check for p2 identifier like "1p2: Woobat" or "1p2a: Woobat"
        if part:match("%dp2[a-z]*:%s*") then
            isP2 = true
            -- The next part should be the details: "Woobat, L24, M"
            if parts[i + 1] then
                detailsPart = parts[i + 1]
            end
            -- The part after that is HP: "71/71"
            if parts[i + 2] then
                hpPart = parts[i + 2]
            end
            break
        end
    end
    
    if not isP2 or not detailsPart then
        return nil
    end
    
    -- Parse details: "Woobat, L24, M" or "Woobat, L24, M, shiny"
    local name, level, gender, extra = detailsPart:match("^(.+), L(%d+), (%a+)(.*)")
    if not name then
        -- Try without gender
        name, level = detailsPart:match("^(.+), L(%d+)")
    end
    
    if not name then return nil end
    
    -- Trim whitespace
    name = name:match("^%s*(.-)%s*$")
    
    -- Check for shiny
    local isShiny = false
    if extra and extra:lower():find("shiny") then
        isShiny = true
    end
    
    -- Parse HP: "71/71" or "71/71;0.5" (with status modifier)
    local currentHP, maxHP = "?", "?"
    if hpPart then
        local hp1, hp2 = hpPart:match("^(%d+)/(%d+)")
        if hp1 then
            currentHP = hp1
            maxHP = hp2
        end
    end
    
    return {
        Name     = name,
        Level    = level or "?",
        HP       = currentHP .. "/" .. maxHP,
        IsShiny  = isShiny,
        Shiny    = isShiny and "✨ YES — SHINY!" or "No"
    }
end

-- Parse the full update data (table of pipe-delimited strings) for p2 entries
local function parseUpdateForOpponent(updateData)
    if type(updateData) ~= "table" then
        -- Could be a single string
        if type(updateData) == "string" then
            updateData = {updateData}
        else
            return nil
        end
    end
    
    for _, line in ipairs(updateData) do
        if type(line) == "string" then
            -- Check if this line has p2 data (opponent)
            if line:find("p2") then
                -- Try to parse cache or switch entries
                -- Split by the protocol separator pattern
                -- Each entry starts with |command|
                
                -- Find cache entries for p2
                local cachePattern = "|cache|%d+p2[a-z]*:%s*"
                local switchPattern = "|switch|%d+p2[a-z]*:%s*"
                
                if line:find("cache") and line:find("p2") then
                    -- Extract the p2 cache segment
                    -- The format has multiple | separated sections
                    local result = parseP2Entry(line)
                    if result then
                        return result
                    end
                end
                
                if line:find("switch") and line:find("p2") then
                    local result = parseP2Entry(line)
                    if result then
                        return result
                    end
                end
            end
        end
    end
    
    return nil
end

