---------------------------------------------------------------------------
-- HP Update: parse -damage/-heal/faint for p2 from update data
---------------------------------------------------------------------------
local function parseHPUpdate(updateData)
    if type(updateData) ~= "table" then return nil, false end
    local newHP = nil
    local battleEnded = false
    for _, line in ipairs(updateData) do
        if type(line) ~= "string" then continue end
        -- Check for battle end
        if line:find("|win|") or line:find("|tie") then
            battleEnded = true
        end
        -- Check for damage/heal on p2: |-damage|1p2a: Name|HP/MaxHP or |faint|1p2a: Name
        if line:find("p2") then
            if line:find("faint") and line:find("p2") then
                newHP = "0 (FAINTED)"
                battleEnded = true
            end
            local dmgHP = line:match("%-damage|%d*p2[a-z]*:[^|]+|([^|]+)")
            if dmgHP then
                local h1, h2 = dmgHP:match("^(%d+)/(%d+)")
                if h1 then newHP = h1 .. "/" .. h2 end
                if dmgHP:find("fnt") then newHP = "0 (FAINTED)"; battleEnded = true end
            end
            local healHP = line:match("%-heal|%d*p2[a-z]*:[^|]+|([^|]+)")
            if healHP then
                local h1, h2 = healHP:match("^(%d+)/(%d+)")
                if h1 then newHP = h1 .. "/" .. h2 end
            end
        end
    end
    return newHP, battleEnded
end

---------------------------------------------------------------------------
-- Webhook sender
---------------------------------------------------------------------------
local function sendWebhook(data)
    if webhookUrl == "" then return end
    local color = data.IsShiny and 16766720 or 5814783 -- gold or blue
    local payload = HttpService:JSONEncode({
        embeds = {{
            title = data.IsShiny and "✨ SHINY " .. data.Name .. " ✨" or "Wild " .. data.Name,
            color = color,
            fields = {
                {name = "Name", value = data.Name, inline = true},
                {name = "Level", value = "Lv. " .. data.Level, inline = true},
                {name = "HP", value = data.HP, inline = true},
                {name = "Shiny", value = data.Shiny, inline = true},
            },
            footer = {text = "PBB Roria Conquest Hub | Encounter #" .. totalEncounters}
        }}
    })
    local ok, err = pcall(function()
        if request then
            request({Url = webhookUrl, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
        elseif http_request then
            http_request({Url = webhookUrl, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
        elseif syn and syn.request then
            syn.request({Url = webhookUrl, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
        end
    end)
    if not ok then print("[PBB Hub] Webhook error: " .. tostring(err)) end
end

---------------------------------------------------------------------------
-- Auto-catch/flee decision
---------------------------------------------------------------------------
local function shouldCatch(data)
    if autoCatchShiny and data.IsShiny then return true end
    if autoCatchByName and #targetNames > 0 then
        for _, n in ipairs(targetNames) do
            if data.Name:lower() == n:lower() then return true end
        end
    end
    if autoCatchByLevel then
        local lv = tonumber(data.Level) or 0
        if lv >= targetMinLevel and lv <= targetMaxLevel then return true end
    end
    return false
end

local function doAutoAction(catch)
    if not gameRemote or not currentBattleId or not currentRqId then return end
    local cmd = catch and catchCommand or fleeCommand
    local side = currentPlayerSide or "p1"
    pcall(function()
        gameRemote:FireServer("BattleEvent", currentBattleId, "choose", side, currentRqId, cmd)
    end)
    print("[PBB Hub] Auto-" .. (catch and "catch" or "flee") .. ": sent '" .. cmd .. "'")
end

